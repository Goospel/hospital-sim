# ─────────────────────────────────────────────────────────────
#  환경 변수 템플릿  —  이 파일은 git 에 커밋된다 (실제 값은 넣지 않는다).
#  "이 프로젝트를 돌리려면 어떤 값이 필요한가"의 단일 계약(contract).
#
#  ▶ 새 기기(예: 렙탑)에서 이어서 작업할 때:
#      1) 이 파일을 복사      cp .env.example .env.local   (Windows PowerShell 도 cp 별칭 동작)
#      2) .env.local 의 값을 실제 값으로 채운다  (.env.local 은 .gitignore → 커밋 안 됨)
#      3) npm run dev  —  Next.js 가 .env.local 을 자동 로드
#
#  ⚠️ 실제 시크릿(API 키 등)은 절대 이 파일·git 에 넣지 않는다.
#     기기 간 값 이동은:  비밀번호 관리자  또는  발급처(Anthropic Console)에서 재복사.
#     배포(Vercel) 후에는  `vercel env pull .env.local`  로 한 번에 동기화 가능(README 참고).
# ─────────────────────────────────────────────────────────────

# [필수 · 시크릿 · 서버 전용] LLM 대사콜용 API 키 (M2 부터 필요).
#   └ 절대 NEXT_PUBLIC_ 을 붙이지 않는다 — 붙이면 브라우저 번들에 그대로 노출된다.
ANTHROPIC_API_KEY=

# [선택 · 비밀 아님] 사용할 모델 id. 미설정 시 코드 기본값을 쓴다.
#   비밀이 아닌 공통 기본값은 나중에 커밋되는 `.env` 로 옮겨도 된다.
# ANTHROPIC_MODEL=claude-sonnet-5
